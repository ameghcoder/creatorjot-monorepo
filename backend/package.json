{
  "name": "backend",
  "version": "1.0.0",
  "description": "creatorjot backend to handle the yt video id to social media post generation",
  "license": "ISC",
  "author": "Yashraj",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "monitoring": "tsx src/monitoring/run-monitoring.ts",
    "transcript-worker": "tsx src/worker/run-transcript-worker.ts",
    "generation-worker": "tsx src/worker/run-generation-worker.ts",
    "stuck-detector": "tsx src/worker/run-stuck-detector.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "railway:api": "node dist/server.js",
    "railway:transcript-worker": "node dist/worker/run-transcript-worker.js",
    "railway:generation-worker": "node dist/worker/run-generation-worker.js",
    "railway:stuck-detector": "node dist/worker/run-stuck-detector.js",
    "railway:monitoring": "node dist/monitoring/run-monitoring.js",
    "migrate:up": "echo 'Run migrations via Supabase CLI or dashboard'",
    "migrate:down": "echo 'Run rollback via Supabase CLI or dashboard'",
    "migrate:verify": "echo 'Verify migrations via Supabase dashboard'",
    "test:smoke": "echo 'Smoke tests not yet implemented'",
    "get-token": "tsx src/_testing/scripts/get-token.ts"
  },
  "dependencies": {
    "@creatorjot/shared": "workspace:*",
    "@sentry/node": "^9",
    "@supabase/supabase-js": "^2.98.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lru-cache": "^11.2.6",
    "pg": "^8.20.0",
    "pg-boss": "^9.0.3",
    "resend": "^6.9.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}